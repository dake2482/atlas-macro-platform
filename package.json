{
  "name": "atlas-macro-web",
  "version": "0.1.0",
  "private": true,
  "description": "Presentation assets for the Atlas Macro clean-room research platform",
  "scripts": {
    "build": "npm run build:css && npm run build:js",
    "build:css": "tailwindcss -c ./assets/tailwind.config.js -i ./assets/css/app.css -o ./research/static/research/css/app.css --minify",
    "build:js": "esbuild ./assets/js/app.js --bundle --minify --target=es2020 --outfile=./research/static/research/js/app.js",
    "dev:css": "tailwindcss -c ./assets/tailwind.config.js -i ./assets/css/app.css -o ./research/static/research/css/app.css --watch",
    "dev:js": "esbuild ./assets/js/app.js --bundle --sourcemap --target=es2020 --outfile=./research/static/research/js/app.js --watch"
  },
  "dependencies": {
    "alpinejs": "^3.14.9",
    "echarts": "^5.6.0"
  },
  "devDependencies": {
    "esbuild": "^0.25.6",
    "tailwindcss": "3.4.17"
  }
}
