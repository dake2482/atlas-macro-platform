# Django
DJANGO_SECRET_KEY=replace-with-a-long-random-value
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,[::1]
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:3080
SITE_NAME=Atlas Macro
SITE_URL=http://localhost:3080
HTTP_PORT=3080
LOG_LEVEL=INFO

# PostgreSQL. docker-compose uses these values for both Django and PostgreSQL.
POSTGRES_DB=atlasmacro
POSTGRES_USER=atlasmacro
POSTGRES_PASSWORD=atlasmacro-local-only
DATABASE_URL=postgresql://atlasmacro:atlasmacro-local-only@db:5432/atlasmacro

# Celery / Redis
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
CELERY_TASK_ALWAYS_EAGER=0

# Optional provider credentials. Keyless official sources remain available;
# missing licensed feeds render explicit gaps and never fall back to demo data.
FRED_API_KEY=
BLS_REGISTRATION_KEY=
BEA_API_KEY=
CENSUS_API_KEY=
GITHUB_TOKEN=
GITHUB_REPOSITORIES=
SEC_USER_AGENT=
RAW_ARTIFACT_ROOT=/app/data/artifacts
NEWS_RSS_FEEDS=
MARKET_DATA_PROVIDER=none
MARKET_DATA_API_KEY=
AI_PROVIDER=
AI_API_KEY=

# Optional observability / object storage integrations
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
OBJECT_STORAGE_ENDPOINT=
OBJECT_STORAGE_BUCKET=
OBJECT_STORAGE_ACCESS_KEY=
OBJECT_STORAGE_SECRET_KEY=
